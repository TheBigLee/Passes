{
  "categories": [
    {
      "title": "## 💥 Breaking Changes",
      "labels": ["breaking"]
    },
    {
      "title": "## 🚀 Features",
      "labels": []
    }
  ],
  "label_extractor": [
    {
      "pattern": "^\\w+(\\(.*\\))?!:.*",
      "target": "breaking",
      "flags": "giu",
      "on_property": "title"
    },
    {
      "pattern": "BREAKING[ -]CHANGE",
      "target": "breaking",
      "flags": "giu",
      "on_property": "title"
    }
  ],
  "template": "#{{CHANGELOG}}",
  "pr_template": "- #{{TITLE}} (##{{NUMBER}})",
  "empty_template": "- no changes",
  "trim_values": true
}
